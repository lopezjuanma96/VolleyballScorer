{
  "name": "backend",
  "scripts": {
    "app": "bun run src/index.ts",
    "dev": "bun run css --watch & bun run --hot src/index.ts",
    "css": "bunx tailwindcss -i ./static/input.css -o ./static/style.css",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.9",
    "tailwindcss": "^4.2.1"
  }
}
